{
  "expo": {
    "name": "Postervia",
    "slug": "novaku-app",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "postervia",
    "splash": {
      "image": "./assets/splash-brand.png",
      "resizeMode": "contain",
      "backgroundColor": "#F67673"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.novaku.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F67673"
      },
      "edgeToEdgeEnabled": true,
      "package": "app.novaku.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F67673",
          "image": "./assets/splash-brand.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#F67673",
            "image": "./assets/splash-brand.png"
          }
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native",
        {
          "organization": "postervia",
          "project": "postervia-ios",
          "url": "https://sentry.io/"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Postervia to access your camera to scan documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Postervia to access your photos to upload documents."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Postervia to access your location so it can detect your city and tailor your tasks and Plaza feed."
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-font",
      [
        "react-native-maps",
        {
          "iosGoogleMapsApiKey": "",
          "androidGoogleMapsApiKey": ""
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f8713ef-dc8c-4a4d-b780-0817b299093b"
      }
    },
    "owner": "lisumchen"
  }
}
