{
  "expo": {
    "name": "Postervia",
    "slug": "novaku-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "postervia",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.novaku.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F1"
      },
      "edgeToEdgeEnabled": true,
      "package": "app.novaku.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Postervia to access your camera to scan documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Postervia to access your photos to upload documents."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Postervia to access your location so it can detect your city and tailor your tasks and Plaza feed."
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
